{
  "name": "openclaw-v2",
  "version": "1.0.0",
  "description": "OpenClaw v2 — affiliate profile, content personalization, and media service",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "start": "node dist/index.js",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "db:seed": "ts-node db/seed.ts",
    "test": "jest",
    "test:unit": "jest --testPathPattern=tests/unit",
    "test:integration": "jest --testPathPattern=tests/integration",
    "test:e2e": "jest --testPathPattern=tests/e2e"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.0",
    "@prisma/client": "^5.22.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/jszip": "^3.4.0",
    "axios": "^1.7.7",
    "bullmq": "^5.18.0",
    "cookie-parser": "^1.4.7",
    "express": "^4.21.1",
    "form-data": "^4.0.1",
    "googleapis": "^171.4.0",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "jszip": "^3.10.1",
    "mammoth": "^1.8.0",
    "multer": "^1.4.5-lts.1",
    "natural": "^8.1.1",
    "pdf-parse": "^1.1.1",
    "pino": "^9.5.0",
    "pino-pretty": "^13.0.0",
    "puppeteer": "^24.41.0",
    "zod": "^3.23.8"
  },
  "engines": {
    "node": "22.x"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.13",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.7.5",
    "@types/pdf-parse": "^1.1.4",
    "jest": "^29.7.0",
    "prisma": "^5.22.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.6.3"
  }
}
